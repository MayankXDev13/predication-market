// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String         @id @default(cuid())
  address         String         @unique
  usdBalance      Int            // in cents (e.g. $100.11 = 10011)
  usdcBalance     Int            @default(0) // USDC balance in cents (1 USDC = 100)
  usdcDepositMemo String?        @unique // unique memo for USDC deposit tracking
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  positions       Position[]
  orders          OrderHistory[]
  transactions    Transaction[]
}

model Market {
  id                    String         @id @default(cuid())
  title                 String
  description           String
  image                 String
  resolutionDescription String          // who decides the outcome, clarity on edge cases
  yesOrderbook          Json            // all open orders for Yes side
  noOrderbook           Json            // all open orders for No side
  totalQty              Int             // total outstanding shares (Yes + No)
  status                MarketStatus    @default(OPEN)
  resolvedOutcome       OutcomeType?
  resolvedAt            DateTime?
  resolvedBy            String?         // userId of the resolver
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  positions             Position[]
  orders                OrderHistory[]
}

model Position {
  id       String       @id @default(cuid())
  marketId String
  userId   String
  type     PositionType

  user   User   @relation(fields: [userId], references: [id])
  market Market @relation(fields: [marketId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  qty       Int
  @@unique([userId, marketId, type])
}

model OrderHistory {
  id        String    @id @default(cuid())
  orderType OrderType
  qty       Int
  price     Int
  side      String?   // "yes" | "no"
  userId    String
  marketId  String
  createdAt DateTime  @default(now())

  market Market @relation(fields: [marketId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}

model Transaction {
  id        String             @id @default(cuid())
  userId    String
  type      TransactionType
  amount    Int                // in cents
  signature String?            // Solana tx signature
  status    TransactionStatus  @default(PENDING)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id])
}

enum PositionType {
  Yes
  No
}

enum OrderType {
  Buy
  Sell
  Split
  Merge
}

enum MarketStatus {
  OPEN
  CLOSED
  RESOLVED
}

enum OutcomeType {
  YES
  NO
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  SETTLEMENT
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
}
